PORT=5000
MONGODB_URI=mongodb://localhost:27017/transitops
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=30d
CLIENT_URL=http://localhost:5183

# Cloudinary credentials (vehicle document uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# SMTP Email Config (password reset, license expiry reminders)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
FROM_EMAIL=noreply@transitops.io
